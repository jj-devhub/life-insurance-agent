# ============================================================
# Life Insurance Support Assistant - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- LLM Provider Configuration ---
# Supported providers: "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI Configuration (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama Configuration (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Application Settings ---
APP_NAME=Life Insurance Support Assistant
LOG_LEVEL=INFO
DEBUG=false

# --- Paths ---
KNOWLEDGE_BASE_PATH=./knowledge_base
QDRANT_PATH=./data/qdrant_db
MEM0_DB_PATH=./data/mem0_db

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Memory (Mem0) ---
MEM0_ENABLED=true
MEMORY_SEARCH_LIMIT=5

# --- Qdrant Vector Store ---
QDRANT_COLLECTION_NAME=life_insurance_kb
QDRANT_EMBEDDING_SIZE=1536
